# ============================================================
# 환경 변수 템플릿 (.env.example)
# ============================================================
# 사용 방법:
#   1. 이 파일을 .env 로 복사: cp .env.example .env
#   2. 아래 각 항목에 본인 계정 정보를 입력
#   3. .env 파일은 절대 깃허브에 올리지 마세요 (.gitignore에 등록되어 있음)
# ============================================================

# --- Copernicus Marine Service (해양·기상 데이터) ---
# 가입: https://marine.copernicus.eu (무료)
COPERNICUS_MARINE_USER=your_copernicus_username
COPERNICUS_MARINE_PASSWORD=your_copernicus_password

# --- CDSE / Copernicus Data Space Ecosystem (Sentinel-1 위성 영상) ---
# 가입: https://dataspace.copernicus.eu (무료)
CDSE_USER=your_cdse_username
CDSE_PASSWORD=your_cdse_password

# --- OpenAI API (What-If 시나리오 자동 생성) ---
# 발급: https://platform.openai.com/api-keys (유료)
# 헤드리스 배포(AWS) 호환. gpt-4o-mini function calling 사용.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# (선택) 모델 변경 — 미설정 시 gpt-4o-mini
# WHATIF_OPENAI_MODEL=gpt-4o-mini

# --- (레거시) Anthropic Claude API ---
# 현재 What-If 는 OpenAI 를 사용. Claude Max OAuth 기반 레거시 생성기용(로컬 전용).
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Neon PostgreSQL (정형 데이터 DB) ---
# database/.env 의 DATABASE_URL 과 동일한 값 사용.
# 백엔드 읽기 경로(빙산/SAR/sentinel1/시뮬레이션)가 이 DB를 우선 조회하며,
# 미설정 또는 연결 실패 시 backend/data/*.json 파일로 자동 폴백된다.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- CORS 허용 오리진 (운영 보안) ---
# 미설정 시 모든 오리진 허용(개발 편의). 운영(AWS)에서는 프론트 도메인만
# 콤마로 나열해 제한하는 것을 권장 — 와일드카드 CORS 노출 축소.
# 예: CORS_ALLOWED_ORIGINS=https://arctictwin.com,https://www.arctictwin.com
# CORS_ALLOWED_ORIGINS=
