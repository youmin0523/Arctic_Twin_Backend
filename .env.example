# ============================================================
# 환경 변수 템플릿 (.env.example)
# ============================================================
# 사용 방법:
#   1. 이 파일을 .env 로 복사: cp .env.example .env
#   2. 아래 각 항목에 본인 계정 정보를 입력
#   3. .env 파일은 절대 깃허브에 올리지 마세요 (.gitignore에 등록되어 있음)
# ============================================================

# --- Copernicus Marine Service (해양·기상 데이터) ---
# 가입: https://marine.copernicus.eu (무료)
COPERNICUS_MARINE_USER=your_copernicus_username
COPERNICUS_MARINE_PASSWORD=your_copernicus_password

# --- CDSE / Copernicus Data Space Ecosystem (Sentinel-1 위성 영상) ---
# 가입: https://dataspace.copernicus.eu (무료)
CDSE_USER=your_cdse_username
CDSE_PASSWORD=your_cdse_password

# --- Anthropic Claude API (What-If 시나리오 자동 생성) ---
# 발급: https://console.anthropic.com/ (유료)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
